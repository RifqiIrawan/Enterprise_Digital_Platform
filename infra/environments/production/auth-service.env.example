PORT=8081
APP_ENV=production
DATABASE_URL=postgres://platform:REPLACE_ME_DB_PASSWORD@REPLACE_ME_DB_HOST:5432/auth_service?sslmode=require
REDIS_URL=REPLACE_ME_REDIS_HOST
KAFKA_BROKERS=REPLACE_ME_KAFKA_BROKERS
# Must be identical to api-gateway's JWT_SECRET. Refuses to start without a
# real value once APP_ENV != development -- see internal/config/config.go.
JWT_SECRET=REPLACE_ME_JWT_SECRET
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=168h

# Distributed tracing (Observability Fase 3) -- OTLP/HTTP collector endpoint (Jaeger or equivalent).
OTLP_ENDPOINT=REPLACE_ME_OTLP_ENDPOINT
