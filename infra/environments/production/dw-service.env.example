PORT=8095
# dw-service has no database of its own -- it connects READ-ONLY straight
# into 9 other services' Postgres databases (not through their HTTP APIs),
# unlike every other Go service here which owns a single DATABASE_URL. See
# internal/config/config.go.
FINANCE_DATABASE_URL=postgres://platform:REPLACE_ME_DB_PASSWORD@REPLACE_ME_DB_HOST:5432/finance_service?sslmode=require
SALES_DATABASE_URL=postgres://platform:REPLACE_ME_DB_PASSWORD@REPLACE_ME_DB_HOST:5432/sales_service?sslmode=require
WAREHOUSE_DATABASE_URL=postgres://platform:REPLACE_ME_DB_PASSWORD@REPLACE_ME_DB_HOST:5432/warehouse_service?sslmode=require
HR_DATABASE_URL=postgres://platform:REPLACE_ME_DB_PASSWORD@REPLACE_ME_DB_HOST:5432/hr_service?sslmode=require
PURCHASING_DATABASE_URL=postgres://platform:REPLACE_ME_DB_PASSWORD@REPLACE_ME_DB_HOST:5432/purchasing_service?sslmode=require
PRODUCTION_DATABASE_URL=postgres://platform:REPLACE_ME_DB_PASSWORD@REPLACE_ME_DB_HOST:5432/production_service?sslmode=require
QC_DATABASE_URL=postgres://platform:REPLACE_ME_DB_PASSWORD@REPLACE_ME_DB_HOST:5432/qc_service?sslmode=require
ASSET_DATABASE_URL=postgres://platform:REPLACE_ME_DB_PASSWORD@REPLACE_ME_DB_HOST:5432/asset_service?sslmode=require
IOT_DATABASE_URL=postgres://platform:REPLACE_ME_DB_PASSWORD@REPLACE_ME_DB_HOST:5432/iot_service?sslmode=require
CLICKHOUSE_ADDR=REPLACE_ME_CLICKHOUSE_ADDR
CLICKHOUSE_USER=REPLACE_ME_CLICKHOUSE_USER
CLICKHOUSE_PASSWORD=REPLACE_ME_CLICKHOUSE_PASSWORD
CLICKHOUSE_DATABASE=dw
DW_SYNC_ENABLED=true
DW_SYNC_INTERVAL_SECONDS=300
