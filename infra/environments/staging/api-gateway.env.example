PORT=8079
APP_ENV=staging
AUTH_SERVICE_URL=http://auth-service.staging.internal:8081
COMPANY_SERVICE_URL=http://company-service.staging.internal:8082
RBAC_SERVICE_URL=http://rbac-service.staging.internal:8083
AUDIT_SERVICE_URL=http://audit-service.staging.internal:8084
FINANCE_SERVICE_URL=http://finance-service.staging.internal:8085
HR_SERVICE_URL=http://hr-service.staging.internal:8086
SALES_SERVICE_URL=http://sales-service.staging.internal:8087
PURCHASING_SERVICE_URL=http://purchasing-service.staging.internal:8088
WAREHOUSE_SERVICE_URL=http://warehouse-service.staging.internal:8089
PRODUCTION_SERVICE_URL=http://production-service.staging.internal:8090
QC_SERVICE_URL=http://qc-service.staging.internal:8091
ASSET_SERVICE_URL=http://asset-service.staging.internal:8092
AI_BI_SERVICE_URL=http://ai-bi-service.staging.internal:8093
DW_SERVICE_URL=http://dw-service.staging.internal:8095
IOT_SERVICE_URL=http://iot-service.staging.internal:8094
# Must be identical to auth-service's JWT_SECRET. Refuses to start without a
# real value once APP_ENV != development -- see internal/config/config.go.
JWT_SECRET=REPLACE_ME_JWT_SECRET
CORS_ALLOWED_ORIGIN=https://staging.REPLACE_ME_DOMAIN

# Distributed tracing (Observability Fase 3) -- OTLP/HTTP collector endpoint (Jaeger or equivalent).
OTLP_ENDPOINT=REPLACE_ME_OTLP_ENDPOINT
