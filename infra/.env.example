# Postgres runs natively on this machine, not via docker-compose -- see infra/README.md

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# Only used when running the full app stack (see "Full app stack di Docker" in
# infra/README.md) -- auth-service and api-gateway both sign/verify JWTs with
# this secret, so it must match across the whole running stack. Change it for
# anything beyond local dev.
JWT_SECRET=change-me

# api-gateway's CORS allowlist for the frontend origin.
CORS_ALLOWED_ORIGIN=http://localhost:3000

# Baked into the frontend's JS bundle at build time (Vite), not read at
# container runtime -- rebuild the frontend image after changing this.
VITE_API_BASE_URL=http://localhost:8079
