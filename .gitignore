# Go
backend/services/*/bin/
backend/modules/*/bin/
*.exe
*.test
*.out

# Node / frontend
node_modules/
frontend/web/dist/

# Env
.env
.env.local
*/.env
*/.env.local

# Filled-in staging/production env configs (real secrets) -- only the
# *.env.example templates in infra/environments/ are meant to be committed.
infra/environments/**/*.env
!infra/environments/**/*.env.example

# Local machine-specific docker-compose port remaps, not meant to be shared
infra/docker-compose.override.yml

# Logs
*.log

